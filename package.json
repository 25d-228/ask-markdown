{
  "name": "ask-markdown",
  "displayName": "ask-markdown",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ask-markdown.openPreview",
        "title": "Ask Markdown: Open Preview"
      },
      {
        "command": "ask-markdown.askAboutSelection",
        "title": "Ask Markdown: Ask About Selection"
      }
    ],
    "configuration": {
      "title": "Ask Markdown",
      "properties": {
        "ask-markdown.askCommandId": {
          "type": "string",
          "default": "",
          "markdownDescription": "Command ID invoked after the editor selection is set (e.g. `aichat.newchataction`). Leave blank to skip the AI step — the selection will still be set in the editor."
        },
        "ask-markdown.autoOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the Ask Markdown preview when a markdown file is opened."
        },
        "ask-markdown.showFloatingButton": {
          "type": "boolean",
          "default": true,
          "description": "Show the floating action bar (Ask / Copy / Find in source) when text is selected in the preview."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "markdown-it-source-map": "^0.1.1",
    "markdown-it-texmath": "^1.0.0"
  }
}
