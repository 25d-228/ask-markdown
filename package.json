{
  "name": "ask-markdown",
  "displayName": "ask-markdown",
  "description": "",
  "version": "0.3.21",
  "publisher": "vibe-dog",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "askMarkdown.preview",
        "displayName": "Ask Markdown",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "ask-markdown.showPreview",
        "title": "Ask Markdown: Show Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "ask-markdown.flipToPreview",
        "title": "</>",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ask-markdown.flipToPreview",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "ask-markdown.flipToPreview",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Ask Markdown",
      "properties": {
        "ask-markdown.defaultEditor": {
          "type": "boolean",
          "default": false,
          "description": "Use Ask Markdown as the default editor for .md files."
        },
        "ask-markdown.showFloatingButton": {
          "type": "boolean",
          "default": true,
          "description": "Show the floating action bar (Claude / Find in source) when text is selected in the preview."
        },
        "ask-markdown.translateEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the Translate button in the floating action bar. When enabled, clicking Translate looks up the selected word in an English dictionary (IPA pronunciation + definitions)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "markdown-it-source-map": "^0.1.1",
    "markdown-it-texmath": "^1.0.0",
    "ws": "^8.20.0"
  }
}
